{
  "openapi": "3.0.0",
  "info": {
    "title": "Foodlify",
    "version": "1.0.0",
    "description": "API documentation for a food delivery system"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Cart",
      "description": "Operations related to cart management"
    },
    {
      "name": "Order",
      "description": "Operations related to order management"
    },
    {
      "name": "Order Summary",
      "description": "Operations related to order summaries"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CartItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 10
          },
          "cartId": {
            "type": "integer",
            "example": 1
          },
          "menuItemId": {
            "type": "integer",
            "example": 4
          },
          "quantity": {
            "type": "integer",
            "example": 2
          },
          "itemName": {
            "type": "string",
            "example": "Classic Burger"
          },
          "price": {
            "type": "integer",
            "example": 35
          }
        }
      },
      "CartResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string",
            "example": "Cart retrieved successfully"
          },
          "data": {
            "type": "object",
            "properties": {
              "cartId": {
                "type": "integer",
                "example": 1
              },
              "userId": {
                "type": "integer",
                "example": 1
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CartItem"
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/cart": {
      "post": {
        "tags": ["Cart"],
        "summary": "Add item to cart",
        "description": "Validates the user, creates a new cart if it doesn't exist, and adds item to cart.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["itemId", "itemQuantity"],
                "properties": {
                  "itemId": {
                    "type": "integer",
                    "example": 4
                  },
                  "itemQuantity": {
                    "type": "integer",
                    "example": 2
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Items added to cart successfully" },
          "400": { "description": "Client error" },
          "404": { "description": "Not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "get": {
        "tags": ["Cart"],
        "summary": "View entire cart by customer",
        "responses": {
          "200": {
            "description": "Cart retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartResponse" }
              }
            }
          },
          "404": { "description": "Cart not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Clear entire cart",
        "description": "Removes all items from the customer's cart.",
        "responses": {
          "200": { "description": "Cart cleared successfully" },
          "404": { "description": "Cart not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/cart/{itemId}": {
      "patch": {
        "tags": ["Cart"],
        "summary": "Update item quantity in cart",
        "description": "Updates the quantity of a specific menu item already inside the cart.",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "description": "Item ID",
            "schema": { "type": "integer", "example": 4 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["itemQuantity"],
                "properties": {
                  "itemQuantity": { "type": "integer", "example": 3 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item quantity updated successfully" },
          "400": { "description": "Client Error" },
          "404": { "description": "Cart or MenuItem not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Delete an item from cart",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "description": "Item ID",
            "schema": { "type": "integer", "example": 4 }
          }
        ],
        "responses": {
          "200": { "description": "Item deleted successfully" },
          "400": { "description": "Validation Error" },
          "404": { "description": "Item not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/cart/price-quantity": {
      "get": {
        "tags": ["Cart"],
        "summary": "Get total price and quantity of items in cart",
        "responses": {
          "200": { "description": "Price and quantity retrieved successfully" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/orders": {
      "post": {
        "tags": ["Order"],
        "summary": "Place a new order",
        "description": "Creates a new order from the user's cart.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["addressId", "paymentTypeId", "preferredDate"],
                "properties": {
                  "addressId": { "type": "integer", "example": 1 },
                  "paymentTypeId": { "type": "integer", "example": 1 },
                  "preferredDate": { "type": "string", "example": "2026-05-01" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created successfully" },
          "400": { "description": "Client Error (e.g. Price not match)" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/orders/{orderId}": {
      "get": {
        "tags": ["Order"],
        "summary": "Get single order details",
        "description": "Retrieves the details of a specific order by ID.",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "description": "Order ID",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Order details retrieved successfully" },
          "404": { "description": "Order not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/orders/{orderId}/status": {
      "patch": {
        "tags": ["Order"],
        "summary": "Update order status",
        "description": "Updates the status of an order using the State Design Pattern.",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "description": "Order ID",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["CONFIRMED", "PROCESSED", "READY_TO_PICKUP", "OUT_FOR_DELIVERY", "DELIVERED", "CANCELLED", "REFUNDED"],
                    "example": "CONFIRMED"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order status updated successfully" },
          "400": { "description": "Invalid state transition" },
          "404": { "description": "Order not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/orders/status": {
      "get": {
        "tags": ["Order"],
        "summary": "Get all orders by status",
        "description": "Retrieves all orders for the authenticated customer filtered by order status.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": true,
            "description": "Order status to filter by",
            "schema": {
              "type": "string",
              "enum": ["PENDING", "CONFIRMED", "PROCESSED", "READY_TO_PICKUP", "OUT_FOR_DELIVERY", "DELIVERED", "CANCELLED", "REFUNDED"],
              "example": "PENDING"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Orders retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Order Record retrieved successfully" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "orderId": { "type": "integer", "example": 1 },
                          "totalPrice": { "type": "integer", "example": 150 },
                          "date": { "type": "string", "format": "date-time", "example": "2026-05-01T00:00:00.000Z" },
                          "restaurantName": { "type": "string", "example": "Pizza Palace" },
                          "paymentMethod": { "type": "string", "example": "CASH" },
                          "state": { "type": "string", "example": "Cairo" },
                          "city": { "type": "string", "example": "Nasr City" },
                          "street": { "type": "string", "example": "Abbas El Akkad" },
                          "status": { "type": "string", "example": "PENDING" },
                          "orderDetails": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string", "example": "Classic Burger" },
                                "quantity": { "type": "integer", "example": 2 },
                                "price": { "type": "integer", "example": 35 }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed (invalid status value)" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/order-summary": {
      "get": {
        "tags": ["Order Summary"],
        "summary": "Get all order summaries by customer",
        "responses": {
          "200": { "description": "Order summaries retrieved successfully" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  }
}


