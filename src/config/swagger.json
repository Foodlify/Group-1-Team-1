    "/api/v1/dashboard/users": {
      "get": {
        "tags": ["Dashboard Users"],
        "summary": "Get all dashboard users",
        "description": "Returns all admin-type users. Requires SUPER_ADMIN or ADMIN role.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Users retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":  { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Users retrieved successfully" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DashboardUserResponse" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Insufficient permissions" }
        }
      },
      "post": {
        "tags": ["Dashboard Users"],
        "summary": "Create dashboard user",
        "description": "Creates a new admin-type user with a role. Requires SUPER_ADMIN.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DashboardCreateUserRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":  { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "User created successfully" },
                    "data":    { "$ref": "#/components/schemas/DashboardUserResponse" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Insufficient permissions — SUPER_ADMIN required" },
          "409": { "description": "Email already registered" }
        }
      }
    },

