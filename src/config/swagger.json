{
  "openapi": "3.0.0",
  "info": {
    "title": "Foodlify",
    "version": "1.0.0",
    "description": "API documentation for a food delivery system"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Cart",
      "description": "Operations related to cart management"
    }
  ],
  "paths": {
    "/api/v1/cart/add": {
      "post": {
        "tags": ["Cart"],
        "summary": "Create a cart and add items to it",
        "description": "Validates the user, creates a new cart if it doesn't exist, and adds items ensuring they all belong to the specified restaurant.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId", "restaurantId", "items"],
                "properties": {
                  "userId": {
                    "type": "integer",
                    "example": 1
                  },
                  "restaurantId": {
                    "type": "integer",
                    "example": 2
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["itemId", "quantity"],
                      "properties": {
                        "itemId": {
                          "type": "integer",
                          "example": 4
                        },
                        "quantity": {
                          "type": "integer",
                          "example": 2
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Items added to cart successfully"
          },
          "400": {
            "description": "Client error (e.g., trying to add items from a different restaurant to an existing cart)"
          },
          "402": {
            "description": "Validation error (missing or invalid structure)"
          },
          "404": {
            "description": "User or Menu Item not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/v1/cart/{cartId}": {
      "get": {
        "tags": ["Cart"],
        "summary": "View entire cart",
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cart retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CartResponse"
                }
              }
            }
          },
          "400": {
            "description": "Client Error"
          },
          "402": {
            "description": "Validation Error (invalid cartId format)"
          },
          "404": {
            "description": "Cart not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Clear entire cart",
        "description": "Removes all items from the cart and deletes the cart itself.",
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cart cleared successfully"
          },
          "400": {
            "description": "Client Error"
          },
          "402": {
            "description": "Validation Error (invalid cartId format)"
          },
          "404": {
            "description": "Cart not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/v1/cart/modify/{cartId}": {
      "put": {
        "tags": ["Cart"],
        "summary": "Update item quantity in cart",
        "description": "Updates or sets the quantity of a specific menu item already inside the cart.",
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["menuItemId", "quantity"],
                "properties": {
                  "menuItemId": {
                    "type": "integer",
                    "example": 4
                  },
                  "quantity": {
                    "type": "integer",
                    "example": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item quantity updated successfully"
          },
          "400": {
            "description": "Client Error"
          },
          "402": {
            "description": "Validation Error (invalid positive quantity or missing body)"
          },
          "404": {
            "description": "Cart or MenuItem not found in cart"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CartItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 10
          },
          "cartId": {
            "type": "integer",
            "example": 1
          },
          "menuItemId": {
            "type": "integer",
            "example": 4
          },
          "quantity": {
            "type": "integer",
            "example": 2
          },
          "itemName": {
            "type": "string",
            "example": "Classic Burger"
          },
          "price": {
            "type": "integer",
            "example": 35
          }
        }
      },
      "CartResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string",
            "example": "Cart retrieved successfully"
          },
          "data": {
            "type": "object",
            "properties": {
              "cartId": {
                "type": "integer",
                "example": 1
              },
              "userId": {
                "type": "integer",
                "example": 1
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CartItem"
                }
              }
            }
          }
        }
      }
    }
  }
}
