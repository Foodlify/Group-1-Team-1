// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------------------------------
//                                           ENUMS
//------------------------------------------------------------------------------------------------------
// ─────────────────────────────────────────
// OrderStatus
// ─────────────────────────────────────────

enum OrderStatusEnum {
  PENDING          @map("pending")
  CONFIRMED        @map("confirmed")
  PROCESSED        @map("processed")
  READY_TO_PICKUP  @map("ready_to_pickup")
  OUT_FOR_DELIVERY @map("out_for_delivery")
  DELIVERED        @map("delivered")
  CANCELLED        @map("cancelled")
  REFUNDED         @map("refunded")
}

// ─────────────────────────────────────────
// TransactionStatus
// ─────────────────────────────────────────
enum TransactionStatusEnum {
  PENDING   @map("pending")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
  REFUNDED  @map("refunded")
}

enum PaymentTypeEnum {
  CASH   @map("cash")
  CARD   @map("card")
  WALLET @map("wallet")
  STRIPE @map("stripe")
  PAYPAL @map("paypal")
}

// -----------------------------------------------------------------------------------------------------
//                                           USER TABLES
//------------------------------------------------------------------------------------------------------
// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  customer Customer?
  cartId   Int?
}

// -----------------------------------------------------------------------------------------------------
//                                           CUSTOMER TABLES
//------------------------------------------------------------------------------------------------------
// ─────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────

model Customer {
  id           Int           @id @default(autoincrement())
  userId       Int           @unique @map("user_id")
  user         User          @relation(fields: [userId], references: [id])
  address      Address?
  cart         Cart?
  orders       Order[]
  orderSummary OrderSummary[]
}

// ─────────────────────────────────────────
// Address
// ─────────────────────────────────────────

model Address {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  street     String
  city       String
  state      String?
  country    String
  postalCode String?
  customer   Customer @relation(fields: [customerId], references: [id])
  orders     Order[]
}

// -----------------------------------------------------------------------------------------------------
//                                           RESTAURANT & MENU TABLES
//------------------------------------------------------------------------------------------------------
// ─────────────────────────────────────────
// RESTAURANT
// ─────────────────────────────────────────

model Restaurant {
  id        Int        @id @default(autoincrement())
  name      String
  menus     Menu[]
  carts     Cart[]
  menuItems MenuItem[]
  orders    Order[]
}

// ─────────────────────────────────────────
// MENU
// ─────────────────────────────────────────

model Menu {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  // FK
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]
}

// ─────────────────────────────────────────
// MENU ITEMS
// ─────────────────────────────────────────

model MenuItem {
  id           Int           @id @default(autoincrement())
  menuId       Int           @map("menu_id")
  restaurantId Int           @map("restaurantId")
  itemName     String        @map("item_name")
  price        Int
  stock        Int           @default(0)
  menu         Menu          @relation(fields: [menuId], references: [id])
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
  orderDetails OrderDetail[]
}

// -----------------------------------------------------------------------------------------------------
//                                           CART TABLES
//------------------------------------------------------------------------------------------------------
// ─────────────────────────────────────────
// CART
// ─────────────────────────────────────────

model Cart {
  id           Int        @id @default(autoincrement())
  customerId   Int        @unique @map("customer_id")
  restaurantId Int
  customer     Customer   @relation(fields: [customerId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
}

// ─────────────────────────────────────────
// CART ITEMS
// ─────────────────────────────────────────
model CartItem {
  id         Int      @id @default(autoincrement())
  cartId     Int      @map("cart_id")
  menuItemId Int      @map("menu_item_id")
  quantity   Int
  price      Int
  name       String
  cart       Cart     @relation(fields: [cartId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
}

// -----------------------------------------------------------------------------------------------------
//                                           ORDERS TABLES
//------------------------------------------------------------------------------------------------------

// ─────────────────────────────────────────
// ORDER STATUS
// ─────────────────────────────────────────

model OrderStatus {
  id             Int             @id @default(autoincrement())
  name           OrderStatusEnum @default(PENDING)
  orderTrackings OrderTracking[]
  orders         Order[]
}

// ─────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────

