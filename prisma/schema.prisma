// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  customer Customer?
  cartId   Int?
}

// ─────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────

model Customer {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique @map("user_id")
  user    User     @relation(fields: [userId], references: [id])
  address Address?
  cart    Cart?
  orders  Order[]
}

// ─────────────────────────────────────────
// RESTAURANT
// ─────────────────────────────────────────

model Restaurant {
  id        Int        @id @default(autoincrement())
  name      String
  menus     Menu[]
  carts     Cart[]
  menuItems MenuItem[]
  orders    Order[]
}

// ─────────────────────────────────────────
// MENU
// ─────────────────────────────────────────

model Menu {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  // FK
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]
}

// ─────────────────────────────────────────
// MENU ITEMS
// ─────────────────────────────────────────

model MenuItem {
  id           Int           @id @default(autoincrement())
  menuId       Int           @map("menu_id")
  restaurantId Int           @map("restaurantId")
  itemName     String        @map("item_name")
  price        Int
  stock        Int           @default(0)
  menu         Menu          @relation(fields: [menuId], references: [id])
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
  orderDetails OrderDetail[]
}

// ─────────────────────────────────────────
// CART
// ─────────────────────────────────────────

model Cart {
  id           Int        @id @default(autoincrement())
  customerId   Int        @unique @map("customer_id")
  restaurantId Int
  customer     Customer   @relation(fields: [customerId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
}

// ─────────────────────────────────────────
// CART ITEMS
// ─────────────────────────────────────────

model CartItem {
  id         Int      @id @default(autoincrement())
  cartId     Int      @map("cart_id")
  menuItemId Int      @map("menu_item_id")
  quantity   Int
  price      Int
  name       String
  cart       Cart     @relation(fields: [cartId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
}

// ─────────────────────────────────────────
// ORDER STATUS
// ─────────────────────────────────────────
enum OrderStatus {
  PENDING          @map("pending")
  CONFIRMED        @map("confirmed")
  PROCESSED        @map("processed")
  READY_TO_PICKUP  @map("ready_to_pickup")
  OUT_FOR_DELIVERY @map("out_for_delivery")
  DELIVERED        @map("delivered")
  CANCELLED        @map("cancelled")
  REFUNDED         @map("refunded")
}

model OrderStatusRef {
  id             Int             @id @default(autoincrement())
  status         OrderStatus     @default(PENDING)
  orderTrackings OrderTracking[]
  orders         Order[]
}

// ─────────────────────────────────────────
// TRANSACTION STATUS
// ─────────────────────────────────────────
enum TransactionStatus {
  PENDING   @map("pending")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
  REFUNDED  @map("refunded")
}

model TransactionStatusRef {
  id     Int               @id @default(autoincrement())
  status TransactionStatus @default(PENDING)
}

// ─────────────────────────────────────────
// TRANSACTION STATUS
// ─────────────────────────────────────────
enum PaymentType {
  CASH   @map("cash")
  CARD   @map("card")
  WALLET @map("wallet")
  STRIPE @map("stripe")
  PAYPAL @map("paypal")
}

model PaymentTypeRef {
  id     Int         @id @default(autoincrement())
  name   PaymentType @default(CARD)
  orders Order[]
}

// ─────────────────────────────────────────
// Address
// ─────────────────────────────────────────

model Address {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  street     String
  city       String
  state      String?
  country    String
  postalCode String?
  customer   Customer @relation(fields: [customerId], references: [id])
  orders     Order[]
}

// ─────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────

model Order {
  id            Int      @id @default(autoincrement())
  customerId    Int      @map("customer_id")
  restaurantId  Int      @map("restaurant_id")
  addressId     Int      @map("address_id")
  preferredDate DateTime @map("preferred_date")
  totalPrice    Int      @map("total_price")
  paymentTypeId Int      @map("payment_type_id")
  orderStatusId Int      @map("order_status_id")
  paid          Boolean  @default(false)
  timestamp     DateTime @default(now())

  customer    Customer       @relation(fields: [customerId], references: [id])
  restaurant  Restaurant     @relation(fields: [restaurantId], references: [id])
  address     Address        @relation(fields: [addressId], references: [id])
  paymentType PaymentTypeRef @relation(fields: [paymentTypeId], references: [id])
  orderStatus OrderStatusRef @relation(fields: [orderStatusId], references: [id])

  orderDetails   OrderDetail[]
  orderTrackings OrderTracking[]
  orderSummary   OrderSummary?
}

// ─────────────────────────────────────────
// ORDER DETAIL
// ─────────────────────────────────────────

model OrderDetail {
  id         Int @id @default(autoincrement())
  orderId    Int @map("order_id")
  menuItemId Int @map("menu_item_id")
  price      Int
  quantity   Int
  totalPrice Int @map("total_price")

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

// ─────────────────────────────────────────
// ORDER TRACKING
// ─────────────────────────────────────────

model OrderTracking {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  statusId   Int      @map("status_id")
  statusDate DateTime @default(now()) @map("status_date")

  order  Order          @relation(fields: [orderId], references: [id])
  status OrderStatusRef @relation(fields: [statusId], references: [id])
}

// ─────────────────────────────────────────
// ORDER SUMMARY
// ─────────────────────────────────────────

model OrderSummary {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique @map("order_id")
  restaurantName String   @map("restaurant_name")
  totalAmount    Int      @map("total_amount")
  totalQuantity  Int      @map("total_quantity")
  orderDate      DateTime @map("order_date")

  order Order @relation(fields: [orderId], references: [id])
}
//______________________________________
// Payment 
//______________________________________
model PaymentConfiguration {
payIntegrationId  Int @id @default(autoincrement())
configDetails     Json @default("{}")
}

model Transaction {
  orderId            Int @map("order_id")
  transactionNumber  Int @unique
  amount             Int
  statusId           TransactionStatus 
  payIntegrationId   Int @map("PaymentConfiguration")
}