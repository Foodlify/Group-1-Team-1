// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------------------------------
//                                           ENUMS
//------------------------------------------------------------------------------------------------------

enum OrderStatusEnum {
  PENDING          @map("pending")
  CONFIRMED        @map("confirmed")
  PROCESSED        @map("processed")
  READY_TO_PICKUP  @map("ready_to_pickup")
  OUT_FOR_DELIVERY @map("out_for_delivery")
  DELIVERED        @map("delivered")
  CANCELLED        @map("cancelled")
  REFUNDED         @map("refunded")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

enum TransactionStatusEnum {
  PENDING   @map("pending")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
  REFUNDED  @map("refunded")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

enum PaymentTypeEnum {
  CASH   @map("cash")
  CARD   @map("card")
  WALLET @map("wallet")
  STRIPE @map("stripe")
  PAYPAL @map("paypal")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN             @map("open")
  IN_PROGRESS      @map("in_progress")
  WAITING_CUSTOMER @map("waiting_customer")
  RESOLVED         @map("resolved")
  CLOSED           @map("closed")
  ESCALATED        @map("escalated")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

enum TicketPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

enum TicketCategory {
  ORDER_ISSUE    @map("order_issue")
  PAYMENT        @map("payment")
  DELIVERY_DELAY @map("delivery_delay")
  REFUND         @map("refund")
  ACCOUNT        @map("account")
  OTHERS         @map("others")
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────
enum LoyaltyType {
  EARN   @map("earn")
  REDEEM @map("redeem")
  EXPIRE @map("expire")
}

// -----------------------------------------------------------------------------------------------------
//                                           USER TABLES
//------------------------------------------------------------------------------------------------------

model User {
  orderTrackings OrderTracking[]
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  password       String
  refreshToken   String?
  customer       Customer?
  cartId         Int?
}

// -----------------------------------------------------------------------------------------------------
//                                           CUSTOMER TABLES
//------------------------------------------------------------------------------------------------------

model Customer {
  id                        Int                        @id @default(autoincrement())
  userId                    Int                        @unique @map("user_id")
  phone                     String                     @unique
  dob                       DateTime?
  gender                    String?
  user                      User                       @relation(fields: [userId], references: [id])
  address                   Address?
  cart                      Cart?
  orders                    Order[]
  orderSummary              OrderSummary[]
  supportTickets            SupportTicket[]
  restaurantRates           RestaurantRate[]
  loyaltyPoints             LoyaltyPoints[]
  loyaltyPointsTransactions loyaltyPointsTransaction[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model Address {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  street     String
  city       String
  state      String?
  country    String
  postalCode String?
  customer   Customer @relation(fields: [customerId], references: [id])
  orders     Order[]

  @@unique([id, customerId])
}

// -----------------------------------------------------------------------------------------------------
//                                           RESTAURANT & MENU TABLES
//------------------------------------------------------------------------------------------------------

model Restaurant {
  id              Int              @id @default(autoincrement())
  name            String
  menus           Menu[]
  carts           Cart[]
  menuItems       MenuItem[]
  orders          Order[]
  restaurantRates RestaurantRate[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model Menu {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  // FK
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model MenuItem {
  id           Int           @id @default(autoincrement())
  menuId       Int           @map("menu_id")
  restaurantId Int           @map("restaurantId")
  itemName     String        @map("item_name")
  price        Int
  stock        Int           @default(0)
  menu         Menu          @relation(fields: [menuId], references: [id])
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
  orderDetails OrderDetail[]
}

// -----------------------------------------------------------------------------------------------------
//                                           CART TABLES
//------------------------------------------------------------------------------------------------------

model Cart {
  id           Int        @id @default(autoincrement())
  customerId   Int        @unique @map("customer_id")
  restaurantId Int
  isLocked     Boolean    @default(false)
  lockedAt     DateTime?
  customer     Customer   @relation(fields: [customerId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]

  @@index([customerId])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model CartItem {
  id         Int      @id @default(autoincrement())
  cartId     Int      @map("cart_id")
  menuItemId Int      @map("menu_item_id")
  quantity   Int
  price      Int
  name       String
  cart       Cart     @relation(fields: [cartId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
}

model CartArchive {
  id Int @id @default(autoincrement())

  cartId       Int
  customerId   Int
  restaurantId Int
  archivedAt   DateTime @default(now())
  cartData     Json

  @@index([cartId])
  @@index([customerId])
  @@index([restaurantId])
}

// -----------------------------------------------------------------------------------------------------
//                                           ORDERS TABLES
//------------------------------------------------------------------------------------------------------

model OrderStatus {
  id             Int             @id @default(autoincrement())
  name           OrderStatusEnum @default(PENDING)
  orderTrackings OrderTracking[]
  orders         Order[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model Order {
  id            Int      @id @default(autoincrement())
  customerId    Int      @map("customer_id") //Fk
  restaurantId  Int      @map("restaurant_id") //Fk
  addressId     Int      @map("address_id") //Fk
  paymentTypeId Int      @map("payment_type_id") //Fk
  orderStatusId Int      @map("order_status_id") //Fk 
  preferredDate DateTime @map("preferred_date")
  totalPrice    Int      @map("total_price")
  paid          Boolean  @default(false)
  timestamp     DateTime @default(now())

  customer    Customer               @relation(fields: [customerId], references: [id])
  restaurant  Restaurant             @relation(fields: [restaurantId], references: [id])
  address     Address                @relation(fields: [addressId], references: [id])
  paymentType PaymentIntegrationType @relation(fields: [paymentTypeId], references: [id])
  orderStatus OrderStatus            @relation(fields: [orderStatusId], references: [id])

  orderDetails             OrderDetail[]
  orderTrackings           OrderTracking[]
  orderSummary             OrderSummary?
  transactions             Transaction[]
  supportTickets           SupportTicket[]
  restaurantRate           RestaurantRate[]
  loyaltyPointsTransaction loyaltyPointsTransaction?

  @@unique([id, customerId])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model OrderDetail {
  id           Int    @id @default(autoincrement())
  orderId      Int    @map("order_id")
  menuItemId   Int    @map("menu_item_id")
  menuItemName String @map("menu_item_name")
  price        Int
  quantity     Int

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model OrderTracking {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  statusId   Int      @map("status_id")
  createdBy  Int?     @map("created_by")
  statusDate DateTime @default(now()) @map("status_date")

  order  Order       @relation(fields: [orderId], references: [id])
  status OrderStatus @relation(fields: [statusId], references: [id])
  user   User?       @relation(fields: [createdBy], references: [id])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model OrderSummary {
  id             Int      @id @default(autoincrement())
  customerId     Int      @map("customer_id")
  orderId        Int      @unique @map("order_id")
  restaurantName String   @map("restaurant_name")
  totalAmount    Int      @map("total_amount")
  totalQuantity  Int      @map("total_quantity")
  orderDate      DateTime @map("order_date")

  customer Customer @relation(fields: [customerId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
}

// -----------------------------------------------------------------------------------------------------
//                                           PAYMENT TABLES
//------------------------------------------------------------------------------------------------------

model PaymentIntegrationType {
  id                    Int                   @id @default(autoincrement())
  name                  PaymentTypeEnum       @default(CARD)
  orders                Order[]
  paymentConfigurations PaymentConfiguration?
  transaction           Transaction[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model PaymentConfiguration {
  id            Int                    @id @default(autoincrement()) //PK
  payTypeId     Int                    @unique @map("pay_Type_id") //FK
  configDetails Json                   @default("{}")
  paymentType   PaymentIntegrationType @relation(fields: [payTypeId], references: [id])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model TransactionStatus {
  id          Int                   @id @default(autoincrement())
  status      TransactionStatusEnum @default(PENDING)
  transaction Transaction[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model Transaction {
  id                  Int     @id @default(autoincrement()) //PK
  orderId             Int     @map("order_id") //FK
  receiptId           String  @unique @default(uuid())
  transactionStatusId Int     @map("status_id") //FK
  payTypeId           Int     @map("pay_type_id") //FK
  transactionNumber   String? @unique
  amount              Int
  tax                 Int     @default(0)
  discount            Int     @default(0)

  order             Order                  @relation(fields: [orderId], references: [id])
  paymentType       PaymentIntegrationType @relation(fields: [payTypeId], references: [id])
  transactionStatus TransactionStatus      @relation(fields: [transactionStatusId], references: [id])

  tracking TransactionStatusTracking[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────
model TransactionStatusTracking {
  id            Int                   @id @default(autoincrement())
  transactionId Int                   @map("transaction_id") //FK
  status        TransactionStatusEnum @default(PENDING)
  timestamp     DateTime              @default(now())
  transaction   Transaction           @relation(fields: [transactionId], references: [id])
}

// -----------------------------------------------------------------------------------------------------
//                                         Customer Services TABLES
//------------------------------------------------------------------------------------------------------

model CustomerServiceEmployee {
  id              Int             @id @default(autoincrement())
  name            String
  section         TicketCategory
  assignedTickets Int
  supportTickets  SupportTicket[]
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model SupportTicket {
  id              Int                     @id @default(autoincrement())
  requestId       String                  @unique
  customerId      Int
  orderId         Int?
  category        TicketCategory
  priority        TicketPriority          @default(MEDIUM)
  status          TicketStatus            @default(OPEN)
  subject         String
  description     String
  assignedAgentId Int
  createdAt       DateTime                @default(now())
  updatedAt       DateTime?
  resolution      String?
  resolvedAt      DateTime?
  customer        Customer                @relation(fields: [customerId], references: [id])
  assignedAgent   CustomerServiceEmployee @relation(fields: [assignedAgentId], references: [id])
  order           Order?                  @relation(fields: [orderId], references: [id])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model RestaurantRate {
  id           Int @id @default(autoincrement())
  restaurantId Int
  orderId      Int @unique
  customerId   Int

  rating  Int // 1 to 5
  comment String?

  createdAt DateTime @default(now())

  customer   Customer   @relation(fields: [customerId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([customerId, orderId])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model LoyaltyPoints {
  id                       Int                        @id @default(autoincrement())
  customerId               Int                        @unique
  orderId                  Int                        @unique
  points                   Int                        @default(0)
  expiresAt                DateTime
  customer                 Customer                   @relation(fields: [customerId], references: [id])
  loyaltyPointsTransaction loyaltyPointsTransaction[]

  @@index([customerId])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────

model loyaltyPointsTransaction {
  id         Int  @id @default(autoincrement())
  pointsId   Int  @unique
  customerId Int
  orderId    Int? @unique

  type   LoyaltyType
  points Int

  createdAt DateTime @default(now())

  customer       Customer      @relation(fields: [customerId], references: [id])
  order          Order?        @relation(fields: [orderId], references: [id])
  pointsRelation LoyaltyPoints @relation(fields: [pointsId], references: [id])
}

// ───────────────────────────────────────────────────────────────────────────────────────────────────────
