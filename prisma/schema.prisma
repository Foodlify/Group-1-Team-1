model Order {
  id              Int      @id @default(autoincrement())
  customerId      Int      @map("customer_id") //Fk
  restaurantId    Int      @map("restaurant_id") //Fk
  restaurantName  String
  addressId       Int      @map("address_id") //Fk
  deliveryAddress String
  paymentTypeId   Int      @map("payment_type_id") //Fk
  paymentMethod   String
  orderStatusId   Int      @map("order_status_id") //Fk 
  status          String
  preferredDate   DateTime @map("preferred_date")
  totalPrice      Int      @map("total_price")
  paid            Boolean  @default(false)
  timestamp       DateTime @default(now())

  customer    Customer    @relation(fields: [customerId], references: [id])
  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id])
  address     Address     @relation(fields: [addressId], references: [id])
  paymentType PaymentType @relation(fields: [paymentTypeId], references: [id])
  orderStatus OrderStatus @relation(fields: [orderStatusId], references: [id])

  orderDetails   OrderDetail[]
  orderTrackings OrderTracking[]
  orderSummary   OrderSummary?
  transactions   Transaction[]
}

// ─────────────────────────────────────────
// ORDER DETAIL
// ─────────────────────────────────────────

model OrderDetail {
  id           Int    @id @default(autoincrement())
  orderId      Int    @map("order_id")
  menuItemId   Int    @map("menu_item_id")
  menuItemName String
  price        Int
  quantity     Int
  // totalPrice Int @map("total_price")  no need here

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

// ─────────────────────────────────────────
// ORDER TRACKING
// ─────────────────────────────────────────

model OrderTracking {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  statusId   Int      @map("status_id")
  statusDate DateTime @default(now()) @map("status_date")

  order  Order       @relation(fields: [orderId], references: [id])
  status OrderStatus @relation(fields: [statusId], references: [id])
}

// ─────────────────────────────────────────
// ORDER SUMMARY
// ─────────────────────────────────────────

model OrderSummary {
  id             Int      @id @default(autoincrement())
  customerId     Int      @unique @map("customer_id")
  orderId        Int      @unique @map("order_id")
  restaurantName String   @map("restaurant_name")
  totalAmount    Int      @map("total_amount")
  totalQuantity  Int      @map("total_quantity")
  orderDate      DateTime @map("order_date")

  customer Customer @relation(fields: [customerId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
}

// -----------------------------------------------------------------------------------------------------
//                                           PAYMENT TABLES
//------------------------------------------------------------------------------------------------------

// ─────────────────────────────────────────
// Payment integration type
// ─────────────────────────────────────────

model PaymentType {
  id                    Int                   @id @default(autoincrement())
  name                  PaymentTypeEnum       @default(CARD)
  orders                Order[]
  paymentConfigurations PaymentConfiguration?
  transaction           Transaction[]
}

//______________________________________
// Payment Configuration
//______________________________________

model PaymentConfiguration {
  id            Int         @id @default(autoincrement()) //PK
  payTypeId     Int         @unique @map("pay_Type_id") //FK
  configDetails Json        @default("{}")
  paymentType   PaymentType @relation(fields: [payTypeId], references: [id])
}

// ─────────────────────────────────────────
// TRANSACTION STATUS
// ─────────────────────────────────────────

model TransactionStatus {
  id          Int                   @id @default(autoincrement())
  status      TransactionStatusEnum @default(PENDING)
  transaction Transaction[]
}

//______________________________________
// Transaction
//______________________________________

model Transaction {
  id                  Int @id @default(autoincrement()) //PK
  orderId             Int @unique @map("order_id") //FK
  transactionStatusId Int @unique @map("status_id") //FK
  payTypeId           Int @unique @map("pay_type_id") //FK
  transactionNumber   Int @unique
  amount              Int

  order             Order             @relation(fields: [orderId], references: [id])
  paymentType       PaymentType       @relation(fields: [payTypeId], references: [id])
  transactionStatus TransactionStatus @relation(fields: [transactionStatusId], references: [id])
}

