{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": [
      "node",
      "jest"
    ],
    "isolatedModules": true,
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "prisma/**/*",
    "prisma.config.ts",
    "jest.config.js",
    "lib",
    "prisma_db.ts"
  ]
}