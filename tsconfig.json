{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": ["src/**/*", "tests/**/*", "prisma.config.ts", "jest.config.js", "lib", "prisma_db.ts"]
}
